# AB_AI Backend Configuration Template
# Copy this file to .env and fill in the actual values
# NEVER commit .env file to version control

# Server Configuration
PORT=3000

# Database (MongoDB)
# Option A: Local MongoDB - mongodb://127.0.0.1:27017/parashari_dev
# Option B: Shared DEV MongoDB Atlas - Get URI from team lead
MONGODB_URI=mongodb://subhojit0248:SR6ZhHgtQRZefo17@ac-dckkerq-shard-00-00.veubytp.mongodb.net:27017,ac-dckkerq-shard-00-01.veubytp.mongodb.net:27017,ac-dckkerq-shard-00-02.veubytp.mongodb.net:27017/blog_moderation?ssl=true&replicaSet=atlas-kmamn7-shard-0&authSource=admin&appName=subhojit-cluster

# Payment Gateway (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUB_PRICE_ID=

# Application URLs
DOMAIN=http://localhost:3000
LEARNING_API_URL=http://localhost:5000
LEARNING_PORTAL_URL=http://localhost:5173

# Security
JWT_SECRET=

# Cloudflare Stream (Optional for video features)
CF_STREAM_SECRET=

# Email Service (Gmail SMTP)
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_PASSWORD=

# Blog API (categories + approved blogs)
# Used by `blog.html` to call the backend, and by startup seeding.
BLOG_API_BASE_URL=http://localhost:3000
BLOG_WEBSITE_ID=default-website
SEED_BLOG_CATEGORIES=true
SEED_BLOGS=true

# Optional secondary DB:
# If set, admin approval will upsert into `published_blogs` in this database.
MAIN_SITE_MONGODB_URI=mongodb://subhojit0248:SR6ZhHgtQRZefo17@ac-dckkerq-shard-00-00.veubytp.mongodb.net:27017,ac-dckkerq-shard-00-01.veubytp.mongodb.net:27017,ac-dckkerq-shard-00-02.veubytp.mongodb.net:27017/blog_parashari_db?ssl=true&replicaSet=atlas-kmamn7-shard-0&authSource=admin&appName=subhojit-cluster
